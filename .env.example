# ============================================================
# Auto-Apply Agent — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# User data directory (optional — defaults to ./data)
# ------------------------------------------------------------
# DATA_DIR=./data

# ------------------------------------------------------------
# HH.ru search URLs
# Stored in data/search_urls.txt (one URL per line).
# Generated automatically by onboarding wizard (Block B).
# You can also edit the file directly — add one HH search URL per line.
# ------------------------------------------------------------
# (no env var needed — wizard writes data/search_urls.txt)

# ------------------------------------------------------------
# LLM provider (for cover letter generation)
# Supported: openrouter | anthropic | ollama
# ------------------------------------------------------------
LLM_PROVIDER=openrouter
LLM_API_KEY=your_openrouter_api_key_here
LLM_MODEL=deepseek/deepseek-v3.2          # scoring, form fill, Q&A
COVER_MODEL=anthropic/claude-3-5-haiku    # cover letter only; falls back to LLM_MODEL if unset
RESUME_PARSE_MODEL=google/gemini-2.0-flash-001  # multimodal parser for PDF/image resumes

# ------------------------------------------------------------
# Proxy / VPN (required for RU users to reach LLM APIs)
# Leave empty if not needed.
# ------------------------------------------------------------
# PROXY_URL=socks5://127.0.0.1:1080

# ------------------------------------------------------------
# Session limits
# ------------------------------------------------------------
MAX_VACANCIES=10
MIN_SCORE=60      # Skip vacancies with match score below this threshold (0–100)
MAX_SKIPS=10      # Stop session after N consecutive skips (dedup + score + stop-filter)
FILL_TESTS=false  # false = skip mandatory test forms; true = attempt LLM fill (not yet implemented)

# ------------------------------------------------------------
# Browser mode (true = no window, for servers)
# ------------------------------------------------------------
HEADLESS=false

# ------------------------------------------------------------
# REST API (uvicorn api:app)
# Set a strong random key — all API endpoints require X-API-Key header
# ------------------------------------------------------------
API_KEY=

# ------------------------------------------------------------
# Telegram notifications (optional)
# For pending_actions alerts when LLM can't answer a question.
# ------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
